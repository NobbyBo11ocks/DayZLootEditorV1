<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="Window">
    <Setter Property="Background" Value="#11140F" />
    <Setter Property="FontFamily" Value="Inter" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="#E7E1D5" />
  </Style>

  <Style Selector="TextBlock.app-title">
    <Setter Property="FontSize" Value="20" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="#E6C35C" />
    <Setter Property="LetterSpacing" Value="1.5" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="#E6C35C" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="#A6A294" />
    <Setter Property="FontSize" Value="10.5" />
  </Style>

  <Style Selector="TextBlock.tiny-muted">
    <Setter Property="Foreground" Value="#A6A294" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="LetterSpacing" Value="0.6" />
  </Style>

  <Style Selector="TextBlock.help">
    <Setter Property="Foreground" Value="#D8D2C3" />
    <Setter Property="FontSize" Value="10.5" />
  </Style>

  <Style Selector="TextBlock.metric">
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="#F1EFE8" />
  </Style>

  <Style Selector="TextBlock.metric-small">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="#F1EFE8" />
  </Style>

  <Style Selector="TextBlock.credit">
    <Setter Property="Foreground" Value="#E6C35C" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Opacity" Value="0.72" />
  </Style>

  <Style Selector="TextBlock.footer-text">
    <Setter Property="Foreground" Value="#B8B4A8" />
    <Setter Property="FontSize" Value="10" />
  </Style>

  <Style Selector="Border.hero">
    <Setter Property="Background" Value="#171B13" />
    <Setter Property="BorderBrush" Value="#394128" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="10,4" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="Background" Value="#1A1F16" />
    <Setter Property="BorderBrush" Value="#37412B" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="5" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>

  <Style Selector="Border.warning-card">
    <Setter Property="Background" Value="#2B2314" />
    <Setter Property="BorderBrush" Value="#8B6D28" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="5" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Background" Value="#2C361F" />
    <Setter Property="Foreground" Value="#F2EFE3" />
    <Setter Property="BorderBrush" Value="#53633B" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="6,2" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="11" />
  </Style>


  
  <Style Selector="Button:disabled">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="Foreground" Value="#D7D1C4" />
    <Setter Property="Background" Value="#252B20" />
    <Setter Property="BorderBrush" Value="#4A5240" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="MinHeight" Value="24" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="MinWidth" Value="82" />
  </Style>

  <Style Selector="Button.hero-button">
    <Setter Property="MinWidth" Value="86" />
    <Setter Property="Padding" Value="6,2" />
  </Style>

  <Style Selector="Button.sidebar-fill">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="Button.toolbar-button.compact">
    <Setter Property="MinWidth" Value="46" />
  </Style>

  <Style Selector="Border.info-chip">
    <Setter Property="Background" Value="#1F2519" />
    <Setter Property="BorderBrush" Value="#4B5739" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="6,2" />
  </Style>

  <Style Selector="Border.empty-state.centered">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="Button.nav">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Padding" Value="7,4" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Background" Value="#222A19" />
    <Setter Property="BorderBrush" Value="#6A7D48" />
  </Style>

  <Style Selector="DataGridColumnHeader">
    <Setter Property="Background" Value="#242B1D" />
    <Setter Property="Foreground" Value="#E6C35C" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="10.5" />
    <Setter Property="Padding" Value="6,2" />
    <Setter Property="MinHeight" Value="24" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="#B8902F" />
    <Setter Property="Foreground" Value="#14120A" />
    <Setter Property="BorderBrush" Value="#E6C35C" />
  </Style>

  <Style Selector="Button.danger">
    <Setter Property="Background" Value="#542724" />
    <Setter Property="BorderBrush" Value="#A34A41" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="#11140F" />
    <Setter Property="Foreground" Value="#F1EFE8" />
    <Setter Property="BorderBrush" Value="#465239" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="5,2" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Background" Value="#11140F" />
    <Setter Property="Foreground" Value="#F1EFE8" />
    <Setter Property="BorderBrush" Value="#465239" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="5,2" />
  </Style>

  <Style Selector="NumericUpDown">
    <Setter Property="Background" Value="#11140F" />
    <Setter Property="Foreground" Value="#F1EFE8" />
    <Setter Property="BorderBrush" Value="#5B6B43" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="6,2" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="ShowButtonSpinner" Value="False" />
    <Setter Property="ClipValueToMinMax" Value="True" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="NumericUpDown:pointerover">
    <Setter Property="BorderBrush" Value="#7D8F58" />
  </Style>

  <Style Selector="NumericUpDown:focus-within">
    <Setter Property="BorderBrush" Value="#E6C35C" />
  </Style>

  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="#E7E1D5" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Margin" Value="0,1" />
  </Style>

  <Style Selector="DataGrid">
    <Setter Property="Background" Value="#12160F" />
    <Setter Property="Foreground" Value="#E7E1D5" />
    <Setter Property="FontSize" Value="10.5" />
    <Setter Property="BorderBrush" Value="#3D472F" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="RowBackground" Value="#161A12" />
    <Setter Property="HeadersVisibility" Value="Column" />
    <Setter Property="HorizontalGridLinesBrush" Value="#2B3423" />
    <Setter Property="VerticalGridLinesBrush" Value="#21281B" />
  </Style>

  <Style Selector="ListBox">
    <Setter Property="Background" Value="#11140F" />
    <Setter Property="BorderBrush" Value="#37412B" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
  </Style>
  <Style Selector="Border.compact-card">
    <Setter Property="Padding" Value="5" />
    <Setter Property="Margin" Value="0" />
  </Style>

  <Style Selector="Border.last-card">
    <Setter Property="Margin" Value="0" />
  </Style>

  <Style Selector="Border.compact-warning">
    <Setter Property="Padding" Value="5" />
  </Style>

  <Style Selector="Border.footer">
    <Setter Property="Background" Value="#171B13" />
    <Setter Property="BorderBrush" Value="#394128" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="Padding" Value="10,0" />
  </Style>


  <Style Selector="Border.metric-card">
    <Setter Property="MinHeight" Value="38" />
  </Style>

  <Style Selector="Border.shortcut-hint">
    <Setter Property="Padding" Value="5,2" />
  </Style>

  <Style Selector="Border.soft-card">
    <Setter Property="Background" Value="#151A12" />
    <Setter Property="BorderBrush" Value="#2E3825" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="6" />
  </Style>

  <Style Selector="Border.welcome-strip">
    <Setter Property="Background" Value="#1A2114" />
    <Setter Property="BorderBrush" Value="#687A46" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Border.selection-hint">
    <Setter Property="Background" Value="#141912" />
    <Setter Property="BorderBrush" Value="#3A4630" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="7,4" />
  </Style>


  <Style Selector="Border.toolbar-group">
    <Setter Property="Background" Value="#151A12" />
    <Setter Property="BorderBrush" Value="#2E3825" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="3" />
    <Setter Property="Margin" Value="0,0,6,6" />
  </Style>

  <Style Selector="Button.toolbar-button">
    <Setter Property="MinWidth" Value="50" />
    <Setter Property="Padding" Value="6,2" />
    <Setter Property="Margin" Value="0" />
  </Style>

  <Style Selector="Button.compact-toggle">
    <Setter Property="MinWidth" Value="50" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Padding" Value="6,2" />
  </Style>

  <Style Selector="Button.subtle">
    <Setter Property="Background" Value="#22281B" />
    <Setter Property="BorderBrush" Value="#465239" />
  </Style>

  <Style Selector="Border.empty-state">
    <Setter Property="Background" Value="#151A12" />
    <Setter Property="BorderBrush" Value="#404B33" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <Style Selector="Border.primary-surface">
    <Setter Property="Background" Value="#1B2017" />
    <Setter Property="BorderBrush" Value="#465239" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="6" />
  </Style>

  <Style Selector="Border.secondary-surface">
    <Setter Property="Background" Value="#151A12" />
    <Setter Property="BorderBrush" Value="#313A28" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="6" />
  </Style>

  <Style Selector="Border.status-chip">
    <Setter Property="Background" Value="#20271A" />
    <Setter Property="BorderBrush" Value="#4A5739" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="7,2" />
  </Style>
  <Style Selector="Border.context-badge">
    <Setter Property="Background" Value="#1A2114" />
    <Setter Property="BorderBrush" Value="#536343" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="7,2" />
  </Style>

  <Style Selector="Border.count-badge">
    <Setter Property="Background" Value="#181D14" />
    <Setter Property="BorderBrush" Value="#445137" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="7,2" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>


  <Style Selector="TextBlock.badge">
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="FontSize" Value="10.5" />
  </Style>

  <Style Selector="DataGridRow">
    <Setter Property="Background" Value="#161A12" />
  </Style>

  <Style Selector="DataGridRow:pointerover">
    <Setter Property="Background" Value="#21281B" />
  </Style>

  <Style Selector="DataGridRow:selected">
    <Setter Property="Background" Value="#2A3520" />
  </Style>

  <Style Selector="DataGridCell">
    <Setter Property="Padding" Value="6,2" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="DataGridCell:current">
    <Setter Property="BorderBrush" Value="#7C8F58" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Button.quick-action">
    <Setter Property="MinWidth" Value="112" />
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="Padding" Value="3" />
  </Style>

  <Style Selector="Border.data-region">
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Border.compact-empty-state">
    <Setter Property="Padding" Value="12" />
  </Style>

  <Style Selector="ListBoxItem:selected">
    <Setter Property="Background" Value="#26311D" />
  </Style>


  <Style Selector="Border.filter-summary">
    <Setter Property="Padding" Value="6,4" />
  </Style>

  <Style Selector="TextBlock.filter-summary-label">
    <Setter Property="Margin" Value="0,0,4,0" />
  </Style>

  <Style Selector="Button.filter-chip">
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Padding" Value="7,1" />
    <Setter Property="Background" Value="#20271A" />
    <Setter Property="BorderBrush" Value="#5E7043" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="FontSize" Value="10.5" />
  </Style>

  <Style Selector="Button.filter-chip:pointerover">
    <Setter Property="BorderBrush" Value="#E6C35C" />
  </Style>

  <Style Selector="Border.insight-card">
    <Setter Property="Background" Value="#171D13" />
    <Setter Property="BorderBrush" Value="#425036" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>


  <Style Selector="Button.help-icon">
    <Setter Property="MinWidth" Value="26" />
    <Setter Property="Width" Value="26" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Button.micro">
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="Padding" Value="6,2" />
  </Style>

</Styles>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DayZLootEditor.Views.MainWindow"
        Title="DayZ Loot Editor - Loot &amp; CE Manager"
        Width="1600"
        Height="900"
        MinWidth="1240"
        MinHeight="720"
        CanResize="False"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">
  <Grid RowDefinitions="Auto,*,24">
    <Border Grid.Row="0" Classes="hero">
      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="14" RowSpacing="5">
        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="1">
          <TextBlock Classes="app-title" Text="DAYZ LOOT EDITOR" />
          <TextBlock Classes="muted" Text="Edit loot, validate, and manage CE files." />
        </StackPanel>

        <StackPanel Grid.Column="1" Grid.RowSpan="4" Spacing="5" VerticalAlignment="Center" HorizontalAlignment="Right" MaxWidth="420">
          <Border Classes="status-chip" HorizontalAlignment="Right">
            <TextBlock Classes="tiny-muted" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
          </Border>
          <TextBlock Classes="tiny-muted"
                     Text="Mission-first: open a folder, review, then save."
                     TextAlignment="Right"
                     TextWrapping="Wrap" />
        </StackPanel>

        <WrapPanel Grid.Row="1"
                   Grid.Column="0"
                   Orientation="Horizontal"
                   HorizontalAlignment="Left"
                   ItemHeight="28"
                   ItemSpacing="5">
          <Button Classes="primary hero-button" Content="Open Mission" Command="{Binding OpenMissionFolderCommand}" ToolTip.Tip="Pick a DayZ mission folder and load its db/types.xml when available. Shortcut: Ctrl+O" />
          <Button Classes="hero-button" Content="Open types.xml" Command="{Binding OpenTypesFileCommand}" ToolTip.Tip="Open a types.xml file directly. Shortcut: Ctrl+Shift+O" />
          <Button Classes="hero-button" Content="Unload" Command="{Binding UnloadLoadedFileCommand}" ToolTip.Tip="Unload the active loot file and keep the mission session open. Unsaved changes will require confirmation." />
          <Button Classes="primary hero-button" Content="Save" Command="{Binding SaveCommand}" ToolTip.Tip="Write the current loot XML back to disk. Shortcut: Ctrl+S" />
          <Button Classes="hero-button" Content="Save Copy" Command="{Binding SaveAsCommand}" ToolTip.Tip="Save the current loot XML to a new path. Shortcut: Ctrl+Shift+S" />
        </WrapPanel>

        <WrapPanel Grid.Row="2"
                   Grid.Column="0"
                   Orientation="Horizontal"
                   ItemHeight="28"
                   ItemSpacing="6"
                   IsVisible="{Binding HasMissionContextBadge}">
          <Border Classes="context-badge">
            <TextBlock Classes="tiny-muted badge" Text="{Binding MissionContextBadgeText}" />
          </Border>
          <Border Classes="context-badge" IsVisible="{Binding HasFileContextBadge}">
            <TextBlock Classes="tiny-muted badge" Text="{Binding FileContextBadgeText}" />
          </Border>
        </WrapPanel>

        <Border Grid.Row="3" Grid.Column="0" Classes="soft-card shortcut-hint">
          <TextBlock Classes="tiny-muted"
                     Text="Shortcuts: Ctrl+O mission • Ctrl+Shift+O types.xml • Ctrl+S save • Ctrl+Shift+S save copy"
                     TextWrapping="Wrap" />
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="8" ColumnDefinitions="228,*" ColumnSpacing="8">
      <Grid Grid.Column="0" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
        <Border Classes="card compact-card">
          <StackPanel Spacing="6">
            <TextBlock Classes="section-title" Text="Workspace" />
            <Button Classes="nav sidebar-fill" Content="Loot Editor Workspace" Command="{Binding ShowLootEditorCommand}" ToolTip.Tip="Edit the active types.xml loot table." />
            <Button Classes="nav sidebar-fill" Content="Custom CE Manager" Command="{Binding ShowCustomCeCommand}" ToolTip.Tip="Create, register, and repair modular CE XML files." />
            <Border Classes="soft-card">
              <TextBlock Classes="help"
                         Text="Loot Editor = core mission balancing. Custom CE Manager = modular add-on files and registration health."
                         TextWrapping="Wrap" />
            </Border>
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Classes="card compact-card">
          <StackPanel Spacing="5">
            <TextBlock Classes="section-title" Text="Mission Session" />
            <TextBlock Classes="tiny-muted" Text="OPENED MISSION" />
            <Border Classes="secondary-surface">
              <TextBlock Text="{Binding MissionDisplayName}" TextWrapping="Wrap" MaxHeight="34" />
            </Border>
            <TextBlock Classes="tiny-muted" Text="CURRENT LOOT FILE" Margin="0,2,0,0" />
            <Border Classes="secondary-surface">
              <TextBlock Text="{Binding FileDisplayName}" TextWrapping="Wrap" MaxHeight="34" />
            </Border>
            <CheckBox Content="Auto-backup before saving" IsChecked="{Binding AutoBackup}" Margin="0,3,0,1" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,3,0,0">
              <StackPanel Spacing="1">
                <TextBlock Classes="tiny-muted" Text="RECENT ACCESS" />
                <TextBlock Classes="tiny-muted" Text="Reuse a recent types.xml or mission folder only when needed." IsVisible="{Binding IsRecentAccessCollapsed}" />
              </StackPanel>
              <Button Grid.Column="1"
                      Classes="toolbar-button subtle compact-toggle"
                      Content="{Binding RecentAccessToggleText}"
                      Command="{Binding ToggleRecentAccessCommand}"
                      ToolTip.Tip="Show or hide recent file controls." />
            </Grid>

            <StackPanel Spacing="5" IsVisible="{Binding IsRecentAccessExpanded}">
              <TextBlock Classes="tiny-muted" Text="RECENT TYPES FILES" />
              <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding RecentTypesFiles}" SelectedItem="{Binding SelectedRecentTypesFile, Mode=TwoWay}" />
              <Button Classes="sidebar-fill" Content="Open Recent types.xml" Command="{Binding OpenSelectedRecentTypesFileCommand}" ToolTip.Tip="Reopen the selected recent loot file." />

              <TextBlock Classes="tiny-muted" Text="RECENT MISSION FOLDERS" Margin="0,2,0,0" />
              <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding RecentMissionFolders}" SelectedItem="{Binding SelectedRecentMissionFolder, Mode=TwoWay}" />
              <Button Classes="sidebar-fill" Content="Open Recent Mission Folder" Command="{Binding OpenSelectedRecentMissionFolderCommand}" ToolTip.Tip="Reload the selected recent mission folder." />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Grid.Row="2" Classes="card compact-card">
          <StackPanel Spacing="6">
            <TextBlock Classes="section-title" Text="Quick Status" />
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="5" ColumnSpacing="5">
              <Border Classes="warning-card compact-warning metric-card">
                <StackPanel>
                  <TextBlock Classes="tiny-muted" Text="LOOT ENTRIES" />
                  <TextBlock Classes="metric" Text="{Binding TotalEntries}" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="warning-card compact-warning metric-card">
                <StackPanel>
                  <TextBlock Classes="tiny-muted" Text="VISIBLE" />
                  <TextBlock Classes="metric" Text="{Binding FilteredCount}" />
                </StackPanel>
              </Border>
              <Border Grid.Row="1" Classes="warning-card compact-warning metric-card">
                <StackPanel>
                  <TextBlock Classes="tiny-muted" Text="LOOT ERRORS" />
                  <TextBlock Classes="metric" Text="{Binding ErrorCount}" />
                </StackPanel>
              </Border>
              <Border Grid.Row="1" Grid.Column="1" Classes="warning-card compact-warning metric-card">
                <StackPanel>
                  <TextBlock Classes="tiny-muted" Text="CE ERRORS" />
                  <TextBlock Classes="metric" Text="{Binding CustomCeErrorCount}" />
                </StackPanel>
              </Border>
              <Border Grid.Row="2" Grid.ColumnSpan="2" Classes="warning-card compact-warning metric-card">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBlock Classes="tiny-muted" Text="UNSAVED LOOT CHANGES" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Classes="metric-small" Text="{Binding DirtyCount}" VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Grid>
          </StackPanel>
        </Border>

        <Border Grid.Row="3" Classes="card compact-card last-card">
          <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <StackPanel Spacing="2">
                <TextBlock Classes="section-title" Text="Quick Help" />
                <TextBlock Classes="tiny-muted" Text="Optional first-run guidance" />
              </StackPanel>
              <Button Grid.Column="1"
                      Classes="toolbar-button subtle compact-toggle"
                      Content="{Binding QuickHelpToggleText}"
                      Command="{Binding ToggleQuickHelpCommand}"
                      ToolTip.Tip="Show or hide the quick start steps." />
            </Grid>

            <Border Grid.Row="1" Classes="soft-card" IsVisible="{Binding IsQuickHelpCollapsed}">
              <TextBlock Classes="muted"
                         Text="First time here? Expand quick steps for a lightweight mission-first checklist."
                         TextWrapping="Wrap" />
            </Border>

            <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsQuickHelpExpanded}">
              <TextBlock Classes="help"
                         Text="1. Open a mission folder.&#x0a;2. Review or edit types.xml.&#x0a;3. Use Custom CE Manager for modular files.&#x0a;4. Preview and validate before saving."
                         TextWrapping="Wrap" />
              <Border Classes="soft-card">
                <TextBlock Classes="muted"
                           Text="Modded class names stay intact, so the editor remains useful for real server setups."
                           TextWrapping="Wrap" />
              </Border>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>

      <Grid Grid.Column="1" IsVisible="{Binding IsLootEditorVisible}" ColumnDefinitions="*,292" ColumnSpacing="8">
        <Grid Grid.Column="0" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="6">

          <Border Classes="card compact-card welcome-strip" IsVisible="{Binding ShowFirstRunWelcome}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="2">
                <TextBlock Classes="section-title" Text="Welcome to the mission-first workflow" />
                <TextBlock Classes="muted"
                           Text="Open a mission folder once to unlock recent access, CE registration context, and a cleaner first-run path."
                           TextWrapping="Wrap" />
              </StackPanel>
              <WrapPanel Grid.Column="1" Orientation="Horizontal" ItemHeight="32" ItemSpacing="6" VerticalAlignment="Center">
                <Button Classes="toolbar-button primary compact" Content="Open Mission Folder" Command="{Binding OpenMissionFolderCommand}" />
                <Button Classes="toolbar-button compact" Content="Open types.xml" Command="{Binding OpenTypesFileCommand}" />
              </WrapPanel>
            </Grid>
          </Border>

          <Border Grid.Row="1" Classes="card compact-card primary-surface">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="3">
                <TextBlock Classes="section-title" Text="Loot Editor" />
                <TextBlock Classes="muted" Text="Edit types.xml values, filter rows fast, validate, and preview save output." TextWrapping="Wrap" />
              </StackPanel>
              <Border Grid.Column="1" Classes="info-chip" VerticalAlignment="Center" MaxWidth="320">
                <TextBlock Text="{Binding ValidationSummary}" TextWrapping="Wrap" MaxWidth="380" />
              </Border>
            </Grid>
          </Border>

          <Border Grid.Row="2" Classes="card compact-card">
            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="*,156" ColumnSpacing="8">
                <TextBox PlaceholderText="Search item name, category, usage, value, tag..."
                         Text="{Binding SearchText, Mode=TwoWay}" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}" />
              </Grid>

              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                <CheckBox Grid.Row="0"
                          Grid.Column="0"
                          Content="Only rows with issues"
                          IsChecked="{Binding ShowOnlyIssues}"
                          VerticalAlignment="Center" />

                <WrapPanel Grid.Row="0"
                           Grid.Column="1"
                           Orientation="Horizontal"
                           ItemHeight="28"
                           ItemSpacing="5">
                  <NumericUpDown Width="90"
                                 Minimum="1"
                                 Maximum="5000"
                                 Increment="10"
                                 Value="{Binding BulkScalePercent}"
                                 ToolTip.Tip="Pick a percentage for visible rows. 100 keeps counts the same, 150 raises Nominal and Min by 50, and 50 cuts them in half." />
                  <Button Classes="toolbar-button compact"
                          Content="{Binding ScaleActionLabel}"
                          Command="{Binding ScaleVisibleCommand}"
                          ToolTip.Tip="{Binding ScaleActionHelpSummary}" />
                  <Button Classes="toolbar-button subtle compact help-icon"
                          Content="?"
                          Command="{Binding ToggleScaleHelpCommand}"
                          ToolTip.Tip="Explain what Adjust Spawn Counts changes." />
                  <Button Classes="toolbar-button subtle compact" Content="Clear" Command="{Binding ClearFiltersCommand}" />
                </WrapPanel>

                <Border Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Classes="soft-card"
                        IsVisible="{Binding IsScaleHelpVisible}">
                  <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding ScaleActionLabel}" />
                    <TextBlock Classes="muted"
                               Text="{Binding ScaleActionHelpSummary}"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="muted"
                               Text="{Binding ScaleActionHelpDetails}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>


                <StackPanel Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Spacing="8">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="6">
                    <TextBlock Classes="tiny-muted"
                               Text="{Binding ProfileTemplateLabel}"
                               VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding ProfileTemplates}"
                              SelectedItem="{Binding SelectedProfileTemplate}"
                              ToolTip.Tip="Pick a beginner-friendly balance preset for the visible rows." />
                    <Button Grid.Column="2"
                            Classes="toolbar-button compact"
                            Content="{Binding ProfileTemplateActionLabel}"
                            Command="{Binding ApplyProfileTemplateCommand}"
                            ToolTip.Tip="{Binding ProfileTemplateHelpSummary}" />
                    <Button Grid.Column="3"
                            Classes="toolbar-button subtle compact help-icon"
                            Content="?"
                            Command="{Binding ToggleProfileTemplateHelpCommand}"
                            ToolTip.Tip="Explain what the balance preset changes." />
                  </Grid>

                  <Border Classes="soft-card"
                          IsVisible="{Binding IsProfileTemplateHelpVisible}">
                    <StackPanel Spacing="4">
                      <TextBlock FontWeight="SemiBold"
                                 Text="{Binding ProfileTemplateLabel}" />
                      <TextBlock Classes="muted"
                                 Text="{Binding ProfileTemplateSummary}"
                                 TextWrapping="Wrap" />
                      <TextBlock Classes="muted"
                                 Text="{Binding ProfileTemplateHelpSummary}"
                                 TextWrapping="Wrap" />
                      <TextBlock Classes="muted"
                                 Text="{Binding ProfileTemplateHelpDetails}"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </StackPanel>

                <WrapPanel Grid.Row="3"
                           Grid.ColumnSpan="2"
                           Orientation="Horizontal"
                           ItemHeight="28"
                           ItemSpacing="5">

                  <Button Classes="toolbar-button" Content="Undo" Command="{Binding UndoCommand}" />
                  <Button Classes="toolbar-button" Content="Redo" Command="{Binding RedoCommand}" />
                  <Button Classes="toolbar-button" Content="Add" Command="{Binding AddEntryCommand}" />
                  <Button Classes="toolbar-button danger" Content="Delete" Command="{Binding DeleteSelectedCommand}" />
                  <Button Classes="toolbar-button" Content="Preview Diff" Command="{Binding GenerateSavePreviewCommand}" />
                  <Button Classes="toolbar-button primary" Content="Validate" Command="{Binding ValidateCommand}" />
                </WrapPanel>
              </Grid>

              <Border Classes="soft-card filter-summary" IsVisible="{Binding HasActiveLootFilterSummary}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                  <WrapPanel Orientation="Horizontal" ItemHeight="30" ItemSpacing="6">
                    <TextBlock Classes="tiny-muted filter-summary-label" Text="ACTIVE FILTERS" VerticalAlignment="Center" />
                    <Button Classes="filter-chip" IsVisible="{Binding HasSearchFilter}" Content="{Binding SearchFilterChipText}" Command="{Binding ClearLootSearchCommand}" ToolTip.Tip="Clear search filter" />
                    <Button Classes="filter-chip" IsVisible="{Binding HasCategoryFilter}" Content="{Binding CategoryFilterChipText}" Command="{Binding ClearLootCategoryFilterCommand}" ToolTip.Tip="Reset category filter" />
                    <Button Classes="filter-chip" IsVisible="{Binding HasIssueFilter}" Content="{Binding IssueFilterChipText}" Command="{Binding ClearLootIssueFilterCommand}" ToolTip.Tip="Show all rows again" />
                    <Button Classes="filter-chip subtle" Content="Reset all" Command="{Binding ClearFiltersCommand}" ToolTip.Tip="Clear all loot filters" />
                  </WrapPanel>
                  <Border Grid.Column="1" Classes="count-badge" IsVisible="{Binding HasLootRowCountSummary}">
                    <TextBlock Classes="tiny-muted badge" Text="{Binding LootRowCountSummaryText}" />
                  </Border>
                </Grid>
              </Border>
            </StackPanel>
          </Border>

          <Border Grid.Row="3" Classes="card compact-card data-region">
            <Grid RowDefinitions="Auto,*" RowSpacing="8">
              <Border Classes="soft-card selection-hint" IsVisible="{Binding ShowLootSelectionHint}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="tiny-muted" Text="NEXT STEP" />
                    <TextBlock Classes="help" Text="Select a loot row to unlock focused editing in the right panel." TextWrapping="Wrap" />
                  </StackPanel>
                  <TextBlock Grid.Column="1"
                             Classes="tiny-muted"
                             Text="Tip: double-check Nominal, Min, Usage, and Value after each selection."
                             VerticalAlignment="Center"
                             TextAlignment="Right" />
                </Grid>
              </Border>

              <Grid Grid.Row="1">
              <DataGrid ItemsSource="{Binding FilteredEntries}"
                      SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      CanUserReorderColumns="True"
                      IsReadOnly="False"
                      FrozenColumnCount="2"
                      RowHeight="26"
                      MinColumnWidth="64">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="State" Binding="{Binding ValidationState}" IsReadOnly="True" Width="58" />
                  <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="230" />
                  <DataGridTextColumn Header="Nom" Binding="{Binding Nominal}" Width="68" />
                  <DataGridTextColumn Header="Min" Binding="{Binding Min}" Width="66" />
                  <DataGridTextColumn Header="Life" Binding="{Binding Lifetime}" Width="74" />
                  <DataGridTextColumn Header="Restock" Binding="{Binding Restock}" Width="78" />
                  <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="110" />
                  <DataGridTextColumn Header="Usage" Binding="{Binding UsagesCsv}" Width="140" />
                  <DataGridTextColumn Header="Value" Binding="{Binding ValuesCsv}" Width="120" />
                </DataGrid.Columns>
              </DataGrid>

              <Border IsVisible="{Binding ShowLootOnboarding}" Classes="empty-state centered">
                <StackPanel Spacing="10" MaxWidth="480" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <TextBlock Classes="section-title" Text="Open a mission folder to start editing loot" />
                  <TextBlock Classes="muted"
                             Text="Load a full DayZ mission for the best workflow, or open a standalone types.xml file if you already know the exact path."
                             TextWrapping="Wrap"
                             TextAlignment="Center" />
                  <WrapPanel HorizontalAlignment="Center" ItemHeight="34" ItemSpacing="8">
                    <Button Classes="primary quick-action" Content="Open Mission Folder" Command="{Binding OpenMissionFolderCommand}" />
                    <Button Classes="quick-action" Content="Open types.xml" Command="{Binding OpenTypesFileCommand}" />
                  </WrapPanel>
                </StackPanel>
              </Border>

              <Border IsVisible="{Binding ShowLootNoResults}" Classes="empty-state centered">
                <StackPanel Spacing="8" MaxWidth="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <TextBlock Classes="section-title" Text="No rows match the current filters" />
                  <TextBlock Classes="muted"
                             Text="Clear the search or category filters to bring loot rows back into view."
                             TextWrapping="Wrap"
                             TextAlignment="Center" />
                  <Button Classes="quick-action" Content="Clear Filters" Command="{Binding ClearFiltersCommand}" HorizontalAlignment="Center" />
                </StackPanel>
              </Border>
              </Grid>
            </Grid>
          </Border>
        </Grid>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
  
          <Border Classes="card compact-card welcome-strip" IsVisible="{Binding ShowFirstRunWelcome}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="2">
                <TextBlock Classes="section-title" Text="Start with a mission folder once" />
                <TextBlock Classes="muted"
                           Text="Custom CE registration becomes much clearer after the app has one mission context to inspect and remember."
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1" Classes="toolbar-button primary compact" Content="Open Mission Folder" Command="{Binding OpenMissionFolderCommand}" VerticalAlignment="Center" />
            </Grid>
          </Border>

          <Border Grid.Row="1" Classes="card compact-card">
              <Grid RowDefinitions="Auto,*" RowSpacing="8">
                <TextBlock Classes="section-title" Text="Current Selection" />

                <Grid Grid.Row="1">
                  <ContentControl Content="{Binding SelectedEntry}" IsVisible="{Binding HasSelectedEntry}">
                    <ContentControl.ContentTemplate>
                      <DataTemplate>
                        <StackPanel Spacing="6">
                          <Border Classes="soft-card insight-card">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                              <TextBlock Classes="tiny-muted" Text="STATE" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="1" Text="{Binding ValidationState}" FontWeight="SemiBold" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="2" Classes="help" Text="{Binding DataContext.SelectedEntryNextAction, RelativeSource={RelativeSource AncestorType=ContentControl}}" TextWrapping="Wrap" MaxWidth="180" />
                            </Grid>
                          </Border>
                          <TextBlock Classes="tiny-muted" Text="NAME" />
                          <TextBox Text="{Binding Name, Mode=TwoWay}" PlaceholderText="Item class name" />

                          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="5">
                            <StackPanel Spacing="3">
                              <TextBlock Classes="tiny-muted" Text="NOMINAL" />
                              <NumericUpDown Minimum="0" Maximum="999999" Value="{Binding Nominal, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="3">
                              <TextBlock Classes="tiny-muted" Text="MIN" />
                              <NumericUpDown Minimum="0" Maximum="999999" Value="{Binding Min, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Spacing="3">
                              <TextBlock Classes="tiny-muted" Text="LIFETIME" />
                              <NumericUpDown Minimum="0" Maximum="99999999" Value="{Binding Lifetime, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="3">
                              <TextBlock Classes="tiny-muted" Text="RESTOCK" />
                              <NumericUpDown Minimum="0" Maximum="99999999" Value="{Binding Restock, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Spacing="3">
                              <TextBlock Classes="tiny-muted" Text="QUANTMIN" />
                              <NumericUpDown Minimum="-1" Maximum="100" Value="{Binding QuantMin, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Spacing="3">
                              <TextBlock Classes="tiny-muted" Text="QUANTMAX" />
                              <NumericUpDown Minimum="-1" Maximum="100" Value="{Binding QuantMax, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Row="3" Spacing="3">
                              <TextBlock Classes="tiny-muted" Text="COST" />
                              <NumericUpDown Minimum="0" Maximum="999999" Value="{Binding Cost, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="1" Spacing="3">
                              <TextBlock Classes="tiny-muted" Text="CATEGORY" />
                              <TextBox Text="{Binding Category, Mode=TwoWay}" PlaceholderText="Food, Weapons, Tools" />
                            </StackPanel>
                          </Grid>

                          <TextBlock Classes="tiny-muted" Text="COUNT FLAGS" />
                          <WrapPanel Orientation="Horizontal" ItemWidth="132" Margin="0,1,0,0">
                            <CheckBox Content="Count in map" IsChecked="{Binding CountInMap, Mode=TwoWay}" />
                            <CheckBox Content="Cargo" IsChecked="{Binding CountInCargo, Mode=TwoWay}" />
                            <CheckBox Content="Hoarder" IsChecked="{Binding CountInHoarder, Mode=TwoWay}" />
                            <CheckBox Content="Player" IsChecked="{Binding CountInPlayer, Mode=TwoWay}" />
                            <CheckBox Content="Crafted" IsChecked="{Binding Crafted, Mode=TwoWay}" />
                            <CheckBox Content="Deloot" IsChecked="{Binding Deloot, Mode=TwoWay}" />
                          </WrapPanel>

                          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="6" RowSpacing="5">
                            <StackPanel Spacing="3">
                              <TextBlock Classes="tiny-muted" Text="USAGE" />
                              <TextBox Text="{Binding UsagesCsv, Mode=TwoWay}" PlaceholderText="Military, Village" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="3">
                              <TextBlock Classes="tiny-muted" Text="VALUE" />
                              <TextBox Text="{Binding ValuesCsv, Mode=TwoWay}" PlaceholderText="Tier1, Tier2" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="3">
                              <TextBlock Classes="tiny-muted" Text="TAG" />
                              <TextBox Text="{Binding TagsCsv, Mode=TwoWay}" PlaceholderText="shelves, floor" />
                            </StackPanel>
                          </Grid>
                        </StackPanel>
                      </DataTemplate>
                    </ContentControl.ContentTemplate>
                  </ContentControl>

                  <Border IsVisible="{Binding IsEntrySelectionEmpty}" Classes="empty-state">
                    <StackPanel Spacing="8">
                      <TextBlock Classes="section-title" Text="No item selected" />
                      <TextBlock Classes="muted"
                                 Text="Click a loot row to inspect and edit values."
                                 TextWrapping="Wrap" />
                      <Border Classes="soft-card">
                        <TextBlock Classes="help"
                                   Text="Choose a row, then edit it here."
                                   TextWrapping="Wrap" />
                      </Border>
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="2" Classes="card compact-card">
              <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="6">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="section-title" Text="Save Preview" />
                    <TextBlock Classes="muted" Text="Diff before saving." TextWrapping="Wrap" />
                  </StackPanel>
                  <Button Grid.Column="1"
                          Classes="toolbar-button subtle compact help-icon"
                          Content="?"
                          Command="{Binding ToggleSavePreviewHelpCommand}"
                          ToolTip.Tip="Explain what Save Preview is for."
                          VerticalAlignment="Top" />
                  <Button Grid.Column="2" Classes="toolbar-button compact" Content="Refresh" Command="{Binding GenerateSavePreviewCommand}" VerticalAlignment="Top" />
                </Grid>

                <Border Grid.Row="1"
                        Classes="soft-card"
                        IsVisible="{Binding IsSavePreviewHelpVisible}">
                  <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding SavePreviewHelpLabel}" />
                    <TextBlock Classes="muted"
                               Text="{Binding SavePreviewHelpSummary}"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="muted"
                               Text="{Binding SavePreviewHelpDetails}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Grid.Row="2" Classes="warning-card compact-warning">
                  <TextBlock Text="{Binding SavePreviewSummary}" TextWrapping="Wrap" />
                </Border>

                <Grid Grid.Row="3">
                  <ScrollViewer IsVisible="{Binding HasSavePreviewSections}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="300">
                    <ItemsControl ItemsSource="{Binding SavePreviewSections}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Classes="warning-card compact-warning" Margin="0,0,0,8" Padding="10">
                            <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
                              <TextBlock Classes="section-title" Text="{Binding Title}" />
                              <TextBlock Grid.Row="1" Classes="muted" Text="{Binding Summary}" TextWrapping="Wrap" />
                              <Grid Grid.Row="2" ColumnDefinitions="Auto,*,*" ColumnSpacing="8">
                                <TextBlock Text="Type" FontWeight="Bold" />
                                <TextBlock Grid.Column="1" Text="Before Save" FontWeight="Bold" />
                                <TextBlock Grid.Column="2" Text="After Save" FontWeight="Bold" />
                              </Grid>

                              <ItemsControl Grid.Row="3" ItemsSource="{Binding Lines}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <Grid ColumnDefinitions="108,*,*" ColumnSpacing="8" Margin="0,0,0,4">
                                      <Border Padding="6,4">
                                        <TextBlock Text="{Binding ChangeKind}" FontWeight="Bold" TextWrapping="Wrap" />
                                      </Border>
                                      <Border Grid.Column="1" Padding="8,6">
                                        <TextBlock Text="{Binding OriginalText}" TextWrapping="Wrap" FontFamily="Consolas, Courier New" />
                                      </Border>
                                      <Border Grid.Column="2" Padding="8,6">
                                        <TextBlock Text="{Binding UpdatedText}" TextWrapping="Wrap" FontFamily="Consolas, Courier New" />
                                      </Border>
                                    </Grid>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="3" Classes="card compact-card last-card">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="6">
                <TextBlock Classes="section-title" Text="Validation Feed" />
                <TextBlock Grid.Row="1" Classes="muted" Text="{Binding ValidationSummary}" TextWrapping="Wrap" />
                <ListBox Grid.Row="2" ItemsSource="{Binding ValidationIssues}" MaxHeight="180">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Margin="5">
                        <TextBlock Text="{Binding SeverityText}" FontWeight="Bold" />
                        <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap" />
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>
          </Grid>
        </ScrollViewer>
      </Grid>

      <Grid Grid.Column="1" IsVisible="{Binding IsCustomCeVisible}" ColumnDefinitions="252,*,292" ColumnSpacing="8">
        <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*" RowSpacing="8">
          <Border Classes="card compact-card primary-surface">
            <StackPanel Spacing="6">
              <TextBlock Classes="section-title" Text="Custom CE File Manager" />
              <TextBlock Classes="muted"
                         Text="Create, register, validate, and maintain modular CE XML files without mixing them into db/types.xml."
                         TextWrapping="Wrap" />
              <Border Classes="soft-card">
                <TextBlock Classes="help"
                           Text="Best for mod packs, attachments, vehicles, and separate balancing files that should stay modular."
                           TextWrapping="Wrap" />
              </Border>
            </StackPanel>
          </Border>

          <Border Grid.Row="1" Classes="card compact-card">
            <StackPanel Spacing="7">
              <TextBlock Classes="section-title" Text="Create or Register File" />
              <TextBlock Classes="tiny-muted" Text="STARTER TEMPLATES" />
              <WrapPanel Orientation="Horizontal" ItemHeight="30" ItemWidth="116">
                <Button Classes="micro" Content="Types" Command="{Binding UseTypesPresetCommand}" />
                <Button Classes="micro" Content="Spawnable" Command="{Binding UseSpawnablePresetCommand}" />
                <Button Classes="micro" Content="Events" Command="{Binding UseEventsPresetCommand}" />
                <Button Classes="micro" Content="Globals" Command="{Binding UseGlobalsPresetCommand}" />
              </WrapPanel>

              <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                <StackPanel Spacing="3">
                  <TextBlock Classes="tiny-muted" Text="FOLDER" />
                  <TextBox Text="{Binding NewCeFolderName, Mode=TwoWay}" PlaceholderText="modtypes" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="3">
                  <TextBlock Classes="tiny-muted" Text="DAYZ CE TYPE" />
                  <ComboBox ItemsSource="{Binding CustomCeTypeOptions}" SelectedItem="{Binding NewCeFileType, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="3">
                  <TextBlock Classes="tiny-muted" Text="FILE NAME" />
                  <TextBox Text="{Binding NewCeFileName, Mode=TwoWay}" PlaceholderText="types_custom.xml" />
                </StackPanel>
                <Border Grid.Row="2" Grid.ColumnSpan="2" Classes="soft-card">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="tiny-muted" Text="PREVIEW" />
                    <TextBlock Classes="muted" Text="{Binding CustomCePreviewSummary}" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </Grid>

              <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button Classes="primary sidebar-fill" Content="Create / Register" Command="{Binding AddCustomCeFileCommand}" />
                <Button Grid.Column="1" Classes="subtle sidebar-fill" Content="Reset Form" Command="{Binding ResetCustomCeFormCommand}" />
              </Grid>

              <TextBlock Classes="help"
                         Text="Use type 'types' for normal loot files. Use 'spawnabletypes' for attachments and cargo presets. Other presets are useful for event/global bundles."
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Border Grid.Row="2" Classes="card compact-card last-card">
            <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
              <TextBlock Classes="section-title" Text="Custom CE Status" />
              <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Border Classes="warning-card compact-warning metric-card">
                  <StackPanel>
                    <TextBlock Classes="tiny-muted" Text="REGISTERED" />
                    <TextBlock Classes="metric" Text="{Binding CustomCeFileCount}" />
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="warning-card compact-warning metric-card">
                  <StackPanel>
                    <TextBlock Classes="tiny-muted" Text="READY" />
                    <TextBlock Classes="metric" Text="{Binding CustomCeReadyCount}" />
                  </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="warning-card compact-warning metric-card">
                  <StackPanel>
                    <TextBlock Classes="tiny-muted" Text="INFO" />
                    <TextBlock Classes="metric" Text="{Binding CustomCeInfoCount}" />
                  </StackPanel>
                </Border>
              </Grid>
              <Button Grid.Row="2" Classes="primary sidebar-fill" Content="Validate CE Setup" Command="{Binding ValidateCustomCeCommand}" />
              <Border Grid.Row="3" Classes="soft-card">
                <TextBlock Classes="muted" Text="{Binding CustomCeStatus}" TextWrapping="Wrap" />
              </Border>
            </Grid>
          </Border>
        </Grid>

        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" RowSpacing="8">
          <Border Classes="card compact-card welcome-strip" IsVisible="{Binding ShowFirstRunWelcome}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="2">
                <TextBlock Classes="section-title" Text="Start with a mission folder once" />
                <TextBlock Classes="muted"
                           Text="Custom CE registration becomes much clearer after the app has one mission context to inspect and remember."
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1"
                      Classes="toolbar-button primary compact"
                      Content="Open Mission Folder"
                      Command="{Binding OpenMissionFolderCommand}"
                      VerticalAlignment="Center" />
            </Grid>
          </Border>

          <Border Grid.Row="1" Classes="card compact-card">
            <StackPanel Spacing="8">
              <TextBlock Classes="section-title" Text="Registered Custom CE Files" />
              <TextBlock Classes="muted"
                         Text="Loaded from cfgeconomycore.xml. Filter, search, open, repair, or remove selected files."
                         TextWrapping="Wrap" />

              <Grid ColumnDefinitions="Auto,168,Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                <TextBlock Text="Filter" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding CustomCeFilterOptions}"
                          SelectedItem="{Binding SelectedCustomCeFilter, Mode=TwoWay}" />
                <TextBlock Grid.Column="2" Text="Search" VerticalAlignment="Center" />
                <TextBox Grid.Column="3"
                         PlaceholderText="folder, file, type, status, path, notes"
                         Text="{Binding CustomCeSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="1"
                           Grid.ColumnSpan="4"
                           Classes="muted"
                           Text="{Binding FilteredCustomCeFileCount, StringFormat='Showing {0} filtered file(s).'}" />
              </Grid>

              <WrapPanel Orientation="Horizontal" ItemHeight="28" ItemSpacing="5">
                <Button Classes="toolbar-button primary" Content="Open CE" Command="{Binding OpenSelectedCustomTypesCommand}" ToolTip.Tip="Open the selected custom CE file." />
                <Button Classes="toolbar-button" Content="Repair Diff" Command="{Binding RefreshSelectedCustomCeDiffCommand}" ToolTip.Tip="Preview the XML repair before changing anything." />
                <Button Classes="toolbar-button" Content="Repair" Command="{Binding RepairSelectedCustomCeCommand}" ToolTip.Tip="Repair the selected CE file root." />
                <Button Classes="toolbar-button subtle" Content="Unregister" Command="{Binding UnregisterSelectedCustomCeCommand}" />
                <Button Classes="toolbar-button danger" Content="Delete" Command="{Binding DeleteSelectedCustomCeCommand}" ToolTip.Tip="Delete the XML file and unregister it." />
              </WrapPanel>

              <Border Classes="soft-card filter-summary" IsVisible="{Binding HasActiveCustomCeFilterSummary}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                  <WrapPanel Orientation="Horizontal" ItemHeight="30" ItemSpacing="6">
                    <TextBlock Classes="tiny-muted filter-summary-label" Text="ACTIVE FILTERS" VerticalAlignment="Center" />
                    <Button Classes="filter-chip" IsVisible="{Binding HasCustomCeStateFilter}" Content="{Binding CustomCeStateFilterChipText}" Command="{Binding ClearCustomCeStateFilterCommand}" ToolTip.Tip="Reset custom CE health filter" />
                    <Button Classes="filter-chip" IsVisible="{Binding HasCustomCeSearchFilter}" Content="{Binding CustomCeSearchFilterChipText}" Command="{Binding ClearCustomCeSearchCommand}" ToolTip.Tip="Clear custom CE search" />
                    <Button Classes="filter-chip subtle" Content="Clear filters" Command="{Binding ClearAllCustomCeFiltersCommand}" ToolTip.Tip="Reset custom CE filters" />
                  </WrapPanel>
                  <Border Grid.Column="1" Classes="count-badge" IsVisible="{Binding HasCustomCeRowCountSummary}">
                    <TextBlock Classes="tiny-muted badge" Text="{Binding CustomCeRowCountSummaryText}" />
                  </Border>
                </Grid>
              </Border>
            </StackPanel>
          </Border>

          <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="8">
            <Border Classes="soft-card selection-hint" IsVisible="{Binding ShowCustomCeSelectionHint}">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="2">
                  <TextBlock Classes="tiny-muted" Text="NEXT STEP" />
                  <TextBlock Classes="help" Text="Select a registered CE row to preview repair diff, status, and file actions." TextWrapping="Wrap" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Classes="tiny-muted"
                           Text="Tip: start with Broken or Duplicate items first."
                           VerticalAlignment="Center"
                           TextAlignment="Right" />
              </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" IsVisible="{Binding HasCustomCeFiles}"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
              <Border Classes="card compact-card data-region">
              <DataGrid ItemsSource="{Binding FilteredCustomCeFiles}"
                        SelectedItem="{Binding SelectedCustomCeFile, Mode=TwoWay}"
                        AutoGenerateColumns="False"
                        CanUserSortColumns="True"
                        CanUserResizeColumns="True"
                        CanUserReorderColumns="True"
                        IsReadOnly="True"
                        RowHeight="26"
                        MinColumnWidth="64"
                        MinWidth="760">
                <DataGrid.Columns>
                  <DataGridTemplateColumn Header="State" Width="92">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Border Background="{Binding StatusBadgeBackground}"
                                BorderBrush="{Binding StatusBadgeBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="8,2"
                                HorizontalAlignment="Left">
                          <TextBlock Text="{Binding StatusBadgeText}"
                                     Foreground="{Binding StatusBadgeForeground}"
                                     FontWeight="Bold" />
                        </Border>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="90" />
                  <DataGridTextColumn Header="Rows" Binding="{Binding ItemCount}" Width="54" />
                  <DataGridTextColumn Header="Folder" Binding="{Binding Folder}" Width="104" />
                  <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="180" />
                  <DataGridTextColumn Header="Path" Binding="{Binding RelativePath}" Width="190" />
                  <DataGridTextColumn Header="Notes" Binding="{Binding IssueSummary}" Width="200" />
                </DataGrid.Columns>
              </DataGrid>
              </Border>
            </ScrollViewer>

            <Border Grid.Row="1" IsVisible="{Binding ShowCustomCeOnboarding}" Classes="empty-state centered">
              <StackPanel Spacing="10" MaxWidth="460" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Classes="section-title" Text="Open a mission folder before managing custom CE files" />
                <TextBlock Classes="muted"
                           Text="The manager needs a mission context so it can inspect cfgeconomycore.xml, register CE files safely, and validate conflicts."
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
                <Button Classes="primary quick-action" Content="Open Mission Folder" Command="{Binding OpenMissionFolderCommand}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>

            <Border Grid.Row="1" IsVisible="{Binding ShowCustomCeEmptyState}" Classes="empty-state centered">
              <StackPanel Spacing="10" MaxWidth="460" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Classes="section-title" Text="No custom CE files registered yet" />
                <TextBlock Classes="muted"
                           Text="Create one from a starter preset or register an existing CE XML file. This area becomes your Ready, Broken, Missing, and Duplicate dashboard after the first file is added."
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
                <WrapPanel HorizontalAlignment="Center" ItemHeight="34" ItemSpacing="8">
                  <Button Classes="primary quick-action" Content="Create / Register CE File" Command="{Binding AddCustomCeFileCommand}" />
                  <Button Classes="quick-action" Content="Validate CE Setup" Command="{Binding ValidateCustomCeCommand}" />
                </WrapPanel>
              </StackPanel>
            </Border>

            <Border Grid.Row="1" IsVisible="{Binding ShowCustomCeNoResults}" Classes="empty-state centered">
              <StackPanel Spacing="8" MaxWidth="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Classes="section-title" Text="No custom CE files match the current filter" />
                <TextBlock Classes="muted"
                           Text="Adjust the status filter or clear the search text to bring registered files back into view."
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
                <Button Classes="quick-action" Content="Validate CE Setup" Command="{Binding ValidateCustomCeCommand}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
          </Grid>
        </Grid>

        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
            <Border Classes="card compact-card">
              <Grid RowDefinitions="Auto,*" RowSpacing="8">
                <StackPanel Spacing="6">
                  <TextBlock Classes="section-title" Text="Selected File Actions" />
                  <TextBlock Classes="help"
                             Text="Open type='types' files, preview repairs, then repair or remove stale registrations."
                             TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="1">
                  <ContentControl Content="{Binding SelectedCustomCeFile}" IsVisible="{Binding HasSelectedCustomCeFile}">
                    <ContentControl.ContentTemplate>
                      <DataTemplate>
                        <StackPanel Spacing="7">
                          <Border Classes="soft-card insight-card">
                            <StackPanel Spacing="3">
                              <TextBlock Classes="section-title" Text="{Binding DataContext.SelectedCustomCeInsightTitle, RelativeSource={RelativeSource AncestorType=ContentControl}}" />
                              <TextBlock Classes="help" Text="{Binding DataContext.SelectedCustomCeNextAction, RelativeSource={RelativeSource AncestorType=ContentControl}}" TextWrapping="Wrap" />
                            </StackPanel>
                          </Border>
                          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <StackPanel Spacing="3">
                              <TextBlock Classes="tiny-muted" Text="SELECTED FILE" />
                              <TextBlock Text="{Binding RelativePath}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="{Binding StatusBadgeBackground}"
                                    BorderBrush="{Binding StatusBadgeBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="8,2"
                                    VerticalAlignment="Top">
                              <TextBlock Text="{Binding StatusBadgeText}"
                                         Foreground="{Binding StatusBadgeForeground}"
                                         FontWeight="Bold" />
                            </Border>
                          </Grid>

                          <TextBlock Classes="tiny-muted" Text="FULL PATH" />
                          <TextBlock Classes="muted" Text="{Binding FullPath}" TextWrapping="Wrap" />
                          <TextBlock Classes="tiny-muted" Text="CURRENT SUMMARY" />
                          <TextBlock Classes="muted" Text="{Binding DataContext.CustomCeSummary, RelativeSource={RelativeSource AncestorType=Window}}" TextWrapping="Wrap" />
                          <TextBlock Classes="tiny-muted" Text="DELETE MODE" />
                          <CheckBox IsChecked="{Binding DataContext.DeleteCustomCeFileOnUnregister, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                    Content="Delete the XML file when I unregister it" />
                        </StackPanel>
                      </DataTemplate>
                    </ContentControl.ContentTemplate>
                  </ContentControl>

                  <Border IsVisible="{Binding IsCustomCeSelectionEmpty}" Classes="empty-state">
                    <StackPanel Spacing="8">
                      <TextBlock Classes="section-title" Text="No file selected" />
                      <TextBlock Classes="muted"
                                 Text="Pick a registered file to inspect its status, preview repair changes, or clean up stale registrations."
                                 TextWrapping="Wrap" />
                      <Border Classes="soft-card">
                        <TextBlock Classes="help"
                                   Text="Next best action: select a CE row, then review repair and conflict details from this rail."
                                   TextWrapping="Wrap" />
                      </Border>
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="card compact-card">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="6">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="section-title" Text="Repair Diff Preview" />
                    <TextBlock Classes="muted"
                               Text="Shows the XML root-fix before repair."
                               TextWrapping="Wrap" />
                  </StackPanel>
                  <Button Grid.Column="1"
                          Content="Refresh"
                          Command="{Binding RefreshSelectedCustomCeDiffCommand}"
                          VerticalAlignment="Top" />
                </Grid>

                <Border Grid.Row="1" Classes="soft-card">
                  <TextBlock Classes="muted" Text="{Binding CustomCeRepairDiffSummary}" TextWrapping="Wrap" />
                </Border>

                <Grid Grid.Row="2">
                  <ScrollViewer IsVisible="{Binding HasCustomCeRepairDiff}"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled"
                                MaxHeight="280">
                    <ItemsControl ItemsSource="{Binding CustomCeRepairDiffSections}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Classes="warning-card compact-warning" Margin="0,0,0,8" Padding="10">
                            <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
                              <TextBlock Classes="section-title" Text="{Binding Title}" />
                              <TextBlock Grid.Row="1" Classes="muted" Text="{Binding Summary}" TextWrapping="Wrap" />
                              <Grid Grid.Row="2" ColumnDefinitions="Auto,*,*" ColumnSpacing="8">
                                <TextBlock Text="Type" FontWeight="Bold" />
                                <TextBlock Grid.Column="1" Text="Before Repair" FontWeight="Bold" />
                                <TextBlock Grid.Column="2" Text="After Repair" FontWeight="Bold" />
                              </Grid>

                              <ItemsControl Grid.Row="3" ItemsSource="{Binding Lines}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <Grid ColumnDefinitions="108,*,*" ColumnSpacing="8" Margin="0,0,0,4">
                                      <Border Padding="6,4">
                                        <TextBlock Text="{Binding ChangeKind}" FontWeight="Bold" TextWrapping="Wrap" />
                                      </Border>
                                      <Border Grid.Column="1" Padding="8,6">
                                        <TextBlock Text="{Binding OriginalText}" TextWrapping="Wrap" FontFamily="Consolas, Courier New" />
                                      </Border>
                                      <Border Grid.Column="2" Padding="8,6">
                                        <TextBlock Text="{Binding UpdatedText}" TextWrapping="Wrap" FontFamily="Consolas, Courier New" />
                                      </Border>
                                    </Grid>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                  <Border IsVisible="{Binding IsCustomCeRepairDiffEmpty}" Classes="empty-state">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="section-title" Text="No repair diff to show" />
                      <TextBlock Classes="muted"
                                 Text="Select a file with a root issue to preview the exact XML change before you repair it."
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="2" Classes="card compact-card last-card">
              <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="6">
                <TextBlock Classes="section-title" Text="Conflict Detector" />
                <TextBlock Grid.Row="1"
                           Classes="muted"
                           Text="Flags duplicate registrations and path/type conflicts in cfgeconomycore.xml so you can clean them up before they become harder to trace."
                           TextWrapping="Wrap" />
                <Border Grid.Row="2" Classes="soft-card">
                  <TextBlock Classes="muted" Text="{Binding CustomCeConflictSummary}" TextWrapping="Wrap" />
                </Border>
                <Grid Grid.Row="3">
                  <ListBox IsVisible="{Binding HasCustomCeConflicts}" ItemsSource="{Binding CustomCeConflictItems}" MaxHeight="220" />

                  <Border IsVisible="{Binding IsCustomCeConflictsEmpty}" Classes="empty-state">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="section-title" Text="No CE conflicts detected" />
                      <TextBlock Classes="muted"
                                 Text="The current registrations do not show duplicate entries or the same path being registered with multiple CE types."
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>
            </Border>
          </Grid>
        </ScrollViewer>
      </Grid>
    </Grid>

    <Border Grid.Row="2" Classes="footer">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Classes="footer-text" Text="Loot + CE workflow ready" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1"
                   Classes="credit"
                   Text="DayZ Loot Editor • Created by &quot;NobbyBollocks&quot;"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   MaxWidth="280" />
      </Grid>
    </Border>
  </Grid>
</Window>
